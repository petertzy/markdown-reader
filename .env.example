# AI Provider Configuration
# Supported values: openrouter, openai, anthropic
AI_PROVIDER=openrouter

# OpenRouter
OPENROUTER_API_KEY=PASTE_OPENROUTER_API_KEY_HERE
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# OpenAI
OPENAI_API_KEY=PASTE_OPENAI_API_KEY_HERE
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=PASTE_ANTHROPIC_API_KEY_HERE
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Compatibility typo key used in some docs (optional)
# AI_PROVIDER=athropic
